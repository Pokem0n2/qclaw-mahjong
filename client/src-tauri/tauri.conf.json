{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QClaw Mahjong",
  "version": "0.1.0",
  "identifier": "com.qclaw.mahjong",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5176",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "QClaw Mahjong - 麻将Roguelike",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
